<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <Description>Media player, recorder and IPTV drivers for the AV Coders device library, including Lumens, Extron SMP, TriplePlay, Vitec and Exterity.</Description>
        <PackageId>AVCoders.MediaPlayer</PackageId>
        <AssemblyName>AVCoders.MediaPlayer</AssemblyName>
        <RootNamespace>AVCoders.MediaPlayer</RootNamespace>
        <LangVersion>default</LangVersion>
